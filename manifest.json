{
  "manifest_version": 3,
  "name": "Bildmarkör för Fortnox",
  "version": "0.4.1",
  "description": "Gulmarkerar \"Visa kopplade bilder\"-ikoner i Fortnox så de blir lätta att hitta. På/av-toggle + räknare. Inofficiellt tillägg.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://*.fortnox.se/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.fortnox.se/*"],
      "css": ["highlight.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Bildmarkör för Fortnox",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
